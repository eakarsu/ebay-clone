# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ebay_clone
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=4000
NODE_ENV=development

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# AI / OpenRouter (used for image search, shopping assistant, content moderation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# Set to 'true' to run the AI content classifier alongside the regex moderator.
AI_MODERATION=false

# Referral rewards — all in the default currency, credited to user_wallets.
REFERRAL_REWARD_SIGNUP=5.00
REFERRAL_REWARD_FIRST_PURCHASE=10.00
REFERRAL_WELCOME_CREDIT=5.00

# Frontend origin used to build referral links.
FRONTEND_URL=http://localhost:3000
